{
  "info": {
    "name": "InklusiKerja API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "tokenKandidat", "value": "" },
    { "key": "tokenPerusahaan", "value": "" },
    { "key": "jobId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Register Kandidat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"kandidat2@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Kandidat Dua\",\n  \"role\": \"kandidat\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "Login Kandidat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"kandidat2@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  var data = pm.response.json();",
              "  if (data && data.token) {",
              "    pm.collectionVariables.set('tokenKandidat', data.token);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Me (Kandidat)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenKandidat}}" }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "Simpan Profil Kandidat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenKandidat}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Kandidat Dua\",\n  \"location\": \"Jakarta\",\n  \"functional_profile\": \"Saya kandidat demo untuk test\",\n  \"disability_type_ids\": [1],\n  \"skills\": [\"JavaScript\", \"Node.js\"]\n}"
        },
        "url": "{{baseUrl}}/api/kandidat/profile"
      }
    },
    {
      "name": "Register Perusahaan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"perusahaan2@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Perusahaan Dua\",\n  \"role\": \"perusahaan\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "Login Perusahaan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"perusahaan2@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  var data = pm.response.json();",
              "  if (data && data.token) {",
              "    pm.collectionVariables.set('tokenPerusahaan', data.token);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Simpan Profil Perusahaan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenPerusahaan}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_name\": \"PT Demo Dua\",\n  \"location\": \"Jakarta\",\n  \"office_conditions\": [\"Ramp akses tersedia\", \"Lift aksesibel\"]\n}"
        },
        "url": "{{baseUrl}}/api/perusahaan/profile"
      }
    },
    {
      "name": "Buat Lowongan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenPerusahaan}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Backend Developer\",\n  \"description\": \"Kami butuh backend developer\",\n  \"location\": \"Jakarta\",\n  \"offered_salary\": \"8000000\",\n  \"job_title_id\": 1,\n  \"required_skills\": [\"Node.js\", \"MySQL\"],\n  \"disability_accommodations\": [\n    { \"disability_type_id\": 1, \"accommodation\": \"Screen reader tersedia\" }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/jobs"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  var data = pm.response.json();",
              "  if (data && data.jobId) {",
              "    pm.collectionVariables.set('jobId', data.jobId);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "List Lowongan",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/jobs"
      }
    },
    {
      "name": "Detail Lowongan",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/jobs/{{jobId}}"
      }
    },
    {
      "name": "Match (Kandidat Lamar)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tokenKandidat}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"job_id\": \"{{jobId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/match"
      }
    },
    {
      "name": "Match Terakhir (Kandidat)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tokenKandidat}}" }
        ],
        "url": "{{baseUrl}}/api/match/last"
      }
    }
  ]
}
